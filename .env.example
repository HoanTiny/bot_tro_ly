# Đổi tên file này thành ".env" và điền giá trị thật của bạn vào

# Token lấy từ @BotFather trên Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# API key lấy từ https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# (Tùy chọn) Turso — database SQLite trên mây, dùng khi chạy bot luân phiên
# nhiều máy để khỏi copy bot.db qua lại. Đăng ký miễn phí tại https://turso.tech
# rồi tạo database, lấy URL (dạng libsql://ten-db-xxx.turso.io) và auth token.
# Bỏ trống 2 dòng này thì bot lưu vào file bot.db cục bộ như bình thường.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
