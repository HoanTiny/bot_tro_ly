# ── Bí mật — TUYỆT ĐỐI không đẩy lên git ─────────────────────────────────
# Chứa Telegram bot token + Anthropic API key. Ai có file này là điều khiển
# được bot và tiêu tiền API của bạn. (.env.example thì ĐƯỢC đẩy — nó chỉ là
# mẫu, không chứa giá trị thật.)
.env

# ── Dữ liệu cá nhân ───────────────────────────────────────────────────────
# Lịch sử chat, ghi chú, chi tiêu của bạn — dữ liệu riêng tư, không phải code
bot.db
# Replica cục bộ khi dùng Turso (kèm các file phụ tự sinh -info, -wal...)
bot_turso.db*

# ── Thư viện và file tạm — người khác tự tạo lại được ────────────────────
# venv nặng hàng trăm MB; ai clone repo chỉ cần chạy pip install -r requirements.txt
venv/
# File bytecode Python tự sinh khi chạy
__pycache__/
*.pyc

# Log khi chạy 24/7 qua Task Scheduler
logs/
